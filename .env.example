# Backend API URL (optional for local dev - Vite proxy uses /api -> localhost:5000)
# For production (e.g. Vercel), set to your backend base URL INCLUDING /api, then redeploy.
# Example: https://music-app-backend-tawny.vercel.app/api
# (No trailing slash.)
VITE_API_URL=https://music-app-backend-tawny.vercel.app/api
